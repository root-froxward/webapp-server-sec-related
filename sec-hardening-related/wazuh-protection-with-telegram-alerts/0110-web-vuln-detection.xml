    <timeframe>30</timeframe>
    <frequency>20</frequency>
    <description>IDOR enumeration — rapid sequential ID access</description>
    <group>idor,web_attack,</group>
    <mitre><id>T1083</id></mitre>
  </rule>

  <rule id="110300" level="15">
    <if_sid>110100,110110,110120,110130,110150</if_sid>
    <same_source_ip/>
    <timeframe>120</timeframe>
    <frequency>3</frequency>
    <description>CRITICAL: Multi-vector web attack from same IP</description>
    <group>multi_vector,web_attack,critical,scanner,</group>
    <mitre><id>T1190</id></mitre>
  </rule>

  <rule id="110301" level="15">
    <if_sid>110102,110150,110160,110161,110162,110221</if_sid>
    <match> 200 | 201 | 302 </match>
    <description>CRITICAL: Possible successful exploitation — attack returned 2xx/302</description>
    <group>exploitation_success,critical,incident,</group>
    <mitre><id>T1190</id></mitre>
  </rule>

</group>
